<% provide(:title, "Sign in") %>

<section>
    <h1>Sign in</h1>

    <%= render partial: "/sessions/form" %>

    <p>
      <% if Clearance.configuration.allow_sign_up? %>
        <%= link_to "Sign up", sign_up_path %> &bull;
      <% end %>
      <%= link_to "forgot password?", new_password_path %>
    </p>
</section>
