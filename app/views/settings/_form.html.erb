<%= form_with(model: setting, local: true) do |form| %>
  <% if setting.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(setting.errors.count, "error") %> prohibited this setting from being saved:</h2>

      <ul>
        <% setting.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :site_name %>
    <%= form.text_field :site_name %>
  </div>

  <div class="field">
    <%= form.label :site_description %>
    <%= form.text_field :site_description %>
  </div>

  <div class="field">
    <%= form.label :email %>
    <%= form.text_field :email %>
  </div>

  <div class="field">
    <%= form.label :tracking_codes %>
    <%= form.text_area :tracking_codes %>
  </div>

  <div class="field">
    <%= form.label :twitter_handle %>
    <%= form.text_field :twitter_handle %>
  </div>

  <div class="field">
    <%= form.label :facebook_handle %>
    <%= form.text_field :facebook_handle %>
  </div>

  <div class="field">
    <%= form.label :instagram_handle %>
    <%= form.text_field :instagram_handle %>
  </div>

  <div class="field">
    <%= form.label :street %>
    <%= form.text_field :street %>
  </div>

  <div class="field">
    <%= form.label :city %>
    <%= form.text_field :city %>
  </div>

  <div class="field">
    <%= form.label :state %>
    <%= form.text_field :state %>
  </div>

  <div class="field">
    <%= form.label :zip %>
    <%= form.text_field :zip %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
