<% provide(:title, "Password reset") %>

<section>
    <h1>
      Reset your password
    </h1>

    <p>
      To be emailed a link to reset your password, please enter your email address.
    </p>

    <%= form_for :password, url: passwords_path do |form| %>
      <fieldset>
        <%= form.label :email %>
        <%= form.text_field :email, type: "email" %>
      </fieldset>

      <fieldset>
        <%= form.submit %>
      </fieldset>
    <% end %>
</section>
